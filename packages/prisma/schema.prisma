datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model DeviceInstallation {
  id               String         @id @default(uuid())
  deviceId         String         @unique // Generated by the app
  deviceSecret     String         // Used for simple device-based auth
  createdAt        DateTime       @default(now())
  lastSeenAt       DateTime       @updatedAt
  appVersion       String?
  config           Json?          // User-specific load engine config
  vdot             Float?         // Current Jack Daniels VDOT
  baselineLevel    String?        // beginner | intermediate | advanced
  
  dataSources      DataSource[]
  workouts         Workout[]
  plannedWorkouts  PlannedWorkout[]
  dailyStates      DailyState[]
  recommendations  Recommendation[]
}

model DataSource {
  id                   String             @id @default(uuid())
  deviceInstallationId String
  deviceInstallation   DeviceInstallation @relation(fields: [deviceInstallationId], references: [id])
  type                 String             // "strava", "hevy", etc.
  status               String             // "connected", "disconnected"
  accessToken          String?
  refreshToken         String?
  expiresAt            DateTime?
  lastSyncAt           DateTime?
  
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([deviceInstallationId, type])
}

model WorkoutRaw {
  id         String   @id @default(uuid())
  source     String   // "strava", "hevy"
  externalId String?  // ID from the source system
  payload    Json
  importedAt DateTime @default(now())

  @@index([source, externalId])
}

model Workout {
  id                   String             @id @default(uuid())
  deviceInstallationId String
  deviceInstallation   DeviceInstallation @relation(fields: [deviceInstallationId], references: [id])
  source               String             // "strava", "hevy", "manual"
  externalId           String?            @unique
  type                 String             // "run", "strength", "walk", etc.
  startedAt            DateTime
  durationSec          Int
  distanceM            Float?
  calories             Float?
  avgHr                Int?
  maxHr                Int?
  elevationGainM       Float?    // elevation gain in meters
  hrZoneTimes          Json?     // { "zone1": 120, "zone2": 300, ... }
  sufferScore          Float?
  title                String?
  notes                String?
  rpe                  Int?      // Rate of Perceived Exertion (1-10)
  vdotAtTime           Float?    // VDOT score at time of workout
  isPlanned            Boolean            @default(false)
  isManual             Boolean            @default(false)
  sessionPurpose       String?            // "b-race", "c-race", "training"
  targetTimeSec       Int?               // Target finish time for planned races
  linkedWorkoutId      String?            // Links a planned race to a completed workout
  dedupeHash           String?            // To prevent duplicates across sources
  
  exercises            StrengthExercise[]
  loadScore            LoadScore?

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model StrengthExercise {
  id           String   @id @default(uuid())
  workoutId    String
  workout      Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name         String
  muscleGroups String[]
  sets         Json     // Array of { reps: number, weight: number, rir?: number, rpe?: number }
}

model PlannedWorkout {
  id                   String             @id @default(uuid())
  deviceInstallationId String
  deviceInstallation   DeviceInstallation @relation(fields: [deviceInstallationId], references: [id])
  date                 DateTime
  type                 String             // "run", "strength"
  targetDuration       Int?
  targetDistance       Float?
  targetIntensity      String?            // "easy", "moderate", "hard", "interval", etc.
  notes                String?
  
  recommendations      Recommendation[]
}

model LoadScore {
  id            String  @id @default(uuid())
  workoutId    String  @unique
  workout      Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  cardio       Float   @default(0)
  legs         Float   @default(0)
  upper        Float   @default(0)
  core         Float   @default(0)
  systemic     Float   @default(0)
  sourceDetail Json?   // raw contribution breakdown
}

model DailyState {
  id                   String             @id @default(uuid())
  deviceInstallationId String
  deviceInstallation   DeviceInstallation @relation(fields: [deviceInstallationId], references: [id])
  date                 DateTime           @unique
  readiness            Float?
  cardioFatigue        Float              @default(0)
  legFatigue           Float              @default(0)
  upperFatigue         Float              @default(0)
  systemicFatigue      Float              @default(0)
}

model Recommendation {
  id                   String             @id @default(uuid())
  deviceInstallationId String
  deviceInstallation   DeviceInstallation @relation(fields: [deviceInstallationId], references: [id])
  date                 DateTime
  plannedWorkoutId     String?
  plannedWorkout       PlannedWorkout?    @relation(fields: [plannedWorkoutId], references: [id])
  recommendationType   String             // "keep", "reduce", "move", "skip"
  reason               String?
  confidence           Float?
  payload              Json?              // Additional recommendation metadata
  
  createdAt            DateTime           @default(now())
}
